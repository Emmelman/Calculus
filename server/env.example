# Скопируйте в server/.env и впишите свой ключ OpenRouter:
#   cp server/env.example server/.env
# Файл server/.env в .gitignore — НЕ коммитьте реальный ключ (репозиторий публичный).

# Ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Базовый URL (обычно менять не нужно)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Модель помощника (дёшево и хорошо для детских задачек)
HELPER_MODEL=openai/gpt-4o-mini

# Порт прокси (vite dev проксирует /api сюда)
PORT=8799
